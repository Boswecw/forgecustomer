# ForgeCustomer environment configuration.
# Copy to `.env` and fill in real values. NEVER commit `.env` or real secrets.

# --- Database (ForgeCustomer Postgres / Supabase) ---
DATABASE_URL=postgres://postgres:postgres@localhost:54322/postgres

# --- Supabase Auth (customer identity) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated
# Service-role key is server-side ONLY. Never ship to any client.
SUPABASE_SERVICE_ROLE_KEY=replace-me

# --- Stripe (payments) ---
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Override only for mocked end-to-end tests.
STRIPE_API_BASE=https://api.stripe.com

# --- Entitlement signing (Ed25519) ---
# Base64-encoded 32-byte Ed25519 private (seed) key. Use a secret manager in prod.
ENTITLEMENT_SIGNING_PRIVATE_KEY=base64-encoded-32-byte-seed
ENTITLEMENT_SIGNING_KEY_ID=entitlement-key-1

# --- DataForge (sanitized downstream events) ---
DATAFORGE_API_URL=https://dataforge.internal/v1/events
DATAFORGE_SERVICE_TOKEN=replace-me

# --- AuthorForge update campaigns ---
# Server-side only. Used to assign stable campaign rollout buckets.
UPDATE_ROLLOUT_SECRET=replace-with-high-entropy-secret
# Optional prefix for relative release_artifacts.storage_key values. Absolute artifact
# URLs in storage_key are used directly.
RELEASE_ARTIFACT_BASE_URL=https://downloads.example.com/authorforge

# --- Admin / operator auth (Forge Command Token Authority) ---
# Forge Command's Token Authority mints EdDSA (Ed25519) operator JWTs (issuer
# "forge_command_local") and calls /v1/admin/*. Reads need any valid operator token;
# mutations need the admin role (carried as roles=["admin"] or scope "admin").
# Verification is by FC's PUBLIC key — no shared secret. Paste FC's SPKI public-key PEM
# (newlines as \n or a real multiline value per your env loader).
ADMIN_JWT_ISSUER=forge_command_local
ADMIN_JWT_AUDIENCE=forgecustomer-admin
ADMIN_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...FC SPKI public key...\n-----END PUBLIC KEY-----\n"

# --- Runtime ---
APP_ENV=development
RUST_LOG=info,forgecustomer_api=debug
HOST=0.0.0.0
PORT=8080

# --- Tunables (entitlement / offline doctrine) ---
ENTITLEMENT_SNAPSHOT_TTL_HOURS=24
OFFLINE_GRACE_DAYS=14
DATABASE_ACQUIRE_TIMEOUT_SECS=30
USAGE_RESERVATION_TTL_SECS=900
USAGE_THRESHOLD_PERCENTS=80,100
DELETION_COOLING_OFF_DAYS=14

# --- Request guards (router-enforced) ---
# Per-request deadline (503 on expiry) and body cap (413 when exceeded).
REQUEST_TIMEOUT_SECS=30
MAX_BODY_BYTES=1048576
# Per-client (per-IP) budget per minute; 429 RATE_LIMITED when exceeded, 0 disables.
RATE_LIMIT_PER_MINUTE=300
