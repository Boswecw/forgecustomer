# ForgeCustomer environment configuration.
# Copy to `.env` and fill in real values. NEVER commit `.env` or real secrets.

# --- Database (ForgeCustomer Postgres / Supabase) ---
DATABASE_URL=postgres://postgres:postgres@localhost:54322/postgres

# --- Supabase Auth (customer identity) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated
# Service-role key is server-side ONLY. Never ship to any client.
SUPABASE_SERVICE_ROLE_KEY=replace-me

# --- Stripe (payments) ---
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Override only for mocked end-to-end tests.
STRIPE_API_BASE=https://api.stripe.com

# --- Entitlement signing (Ed25519) ---
# Base64-encoded 32-byte Ed25519 private (seed) key. Use a secret manager in prod.
ENTITLEMENT_SIGNING_PRIVATE_KEY=base64-encoded-32-byte-seed
ENTITLEMENT_SIGNING_KEY_ID=entitlement-key-1

# --- DataForge (sanitized downstream events) ---
DATAFORGE_API_URL=https://dataforge.internal/v1/events
DATAFORGE_SERVICE_TOKEN=replace-me

# --- Admin / operator auth (Forge Command) ---
# Forge Command is the operator console; it mints operator JWTs from this issuer and
# calls /v1/admin/*. Reads need any valid operator token; mutations need roles=["admin"].
ADMIN_JWT_ISSUER=https://operators.boswell.internal
ADMIN_JWT_AUDIENCE=forgecustomer-admin
ADMIN_JWT_SECRET=replace-me

# --- Runtime ---
APP_ENV=development
RUST_LOG=info,forgecustomer_api=debug
HOST=0.0.0.0
PORT=8080

# --- Tunables (entitlement / offline doctrine) ---
ENTITLEMENT_SNAPSHOT_TTL_HOURS=24
OFFLINE_GRACE_DAYS=14
DATABASE_ACQUIRE_TIMEOUT_SECS=30
USAGE_RESERVATION_TTL_SECS=900
USAGE_THRESHOLD_PERCENTS=80,100
